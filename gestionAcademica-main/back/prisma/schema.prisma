generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")  
}

// =====================================================================
// SISTEMA MULTI-EMPRESA DE GESTIÓN DE PRÁCTICAS PROFESIONALES
// =====================================================================

// ---------------------------------------------------------------------
// Enums del Sistema
// ---------------------------------------------------------------------
enum TipoEmpresa {
  PUBLICA           // Empresa pública / Estatal
  PRIVADA           // Empresa privada
  ONG               // Organización sin fines de lucro
  EDUCATIVA         // Institución educativa
  MIXTA             // Empresa mixta (público-privada)
}

enum TamanoEmpresa {
  MICRO             // 1-10 empleados
  PEQUENA           // 11-50 empleados
  MEDIANA           // 51-250 empleados
  GRANDE            // 251+ empleados
}

enum EstadoEmpresa {
  ACTIVA
  INACTIVA
  EN_REVISION       @map("EN REVISION")
  CONVENIO_VIGENTE  @map("CONVENIO VIGENTE")
  CONVENIO_VENCIDO  @map("CONVENIO VENCIDO")
}

enum RolSupervisor {
  SUPERVISOR_DIRECTO    // Supervisor directo en la empresa
  JEFE_AREA            // Jefe de área
  GERENTE              // Gerente
  COORDINADOR          // Coordinador de prácticas
  TUTOR                // Tutor asignado
}

enum EstadoPractica {
  PENDIENTE
  EN_CURSO          @map("EN CURSO")
  FINALIZADA
  RECHAZADA
  CANCELADA
}

enum EstadoSolicitud {
  BORRADOR
  ENVIADA
  APROBADA
  RECHAZADA
  EN_REVISION       @map("EN REVISION")
}

enum TipoPractica {
  PRACTICA_INICIAL          // Práctica de observación
  PRACTICA_INTERMEDIA       // Práctica de apoyo
  PRACTICA_PROFESIONAL      // Práctica profesional final
  PASANTIA                  // Pasantía
  SERVICIO_COMUNITARIO      // Servicio comunitario
}

enum RolUsuario {
  ADMIN                 // Administrador del sistema
  JEFE_CARRERA         // Jefe de carrera / Coordinador académico
  SECRETARIA           // Secretaria / Asistente administrativo
  ESTUDIANTE           // Estudiante
  SUPERVISOR_EMPRESA   // Supervisor de empresa
  VINCULACION          // Encargado de vinculación con el medio
}

// ---------------------------------------------------------------------
// 1) USUARIO - Sistema de Autenticación
//    Maneja todos los roles del sistema
// ---------------------------------------------------------------------
model Usuario {
  id                Int              @id @default(autoincrement())
  rut               String           @unique
  nombre            String
  email             String           @unique
  password          String
  rol               RolUsuario
  telefono          String?
  activo            Boolean          @default(true)
  fechaCreacion     DateTime         @default(now())
  ultimoAcceso      DateTime?
  
  // Relaciones opcionales según el rol
  estudiante        Estudiante?      // Si es estudiante
  supervisorEmpresa SupervisorEmpresa? // Si es supervisor de empresa
  
  @@map("usuario")
  @@index([email])
  @@index([rol])
}

// ---------------------------------------------------------------------
// 2) EMPRESA - Entidad central para gestión multi-empresa
//    Reemplaza "CentroEducativo" con enfoque empresarial
// ---------------------------------------------------------------------
model Empresa {
  id                Int              @id @default(autoincrement())
  rut               String           @unique
  razonSocial       String
  nombreFantasia    String?
  tipo              TipoEmpresa
  tamano            TamanoEmpresa?
  sector            String?          // Ej: Tecnología, Salud, Educación
  
  // Ubicación
  region            String?
  comuna            String?
  direccion         String?
  ciudad            String?
  
  // Contacto
  telefono          String?
  email             String?
  sitioWeb          String?
  
  // Estado y convenio
  estado            EstadoEmpresa    @default(ACTIVA)
  tieneConvenio     Boolean          @default(false)
  fechaConvenio     DateTime?
  fechaVencimiento  DateTime?
  urlConvenio       String?          // PDF del convenio
  
  // Capacidad
  cuposPracticas    Int?             // Cupos disponibles para prácticas
  areasPractica     String?          // JSON con áreas disponibles
  
  // Metadatos
  fechaRegistro     DateTime         @default(now())
  fechaActualizacion DateTime        @updatedAt
  observaciones     String?          @db.Text
  
  // Relaciones
  supervisores      SupervisorEmpresa[]
  practicas         Practica[]
  solicitudes       SolicitudAutorizacion[]
  
  @@map("empresa")
  @@index([rut])
  @@index([estado])
  @@index([tipo])
}

// ---------------------------------------------------------------------
// 3) SUPERVISOR EMPRESA - Supervisores/Tutores de las empresas
//    Reemplaza "Colaborador" y "TrabajadorEduc"
// ---------------------------------------------------------------------
model SupervisorEmpresa {
  id                Int              @id @default(autoincrement())
  usuarioId         Int?             @unique
  usuario           Usuario?         @relation(fields: [usuarioId], references: [id])
  
  rut               String           @unique
  nombre            String
  email             String
  telefono          String?
  cargo             String?
  rol               RolSupervisor    @default(SUPERVISOR_DIRECTO)
  area              String?          // Área o departamento
  
  // Relación con empresa
  empresaId         Int
  empresa           Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  
  // Información profesional
  profesion         String?
  aniosExperiencia  Int?
  especialidad      String?
  
  // Estado
  activo            Boolean          @default(true)
  fechaIngreso      DateTime         @default(now())
  
  // Relaciones
  practicasAsignadas Practica[]
  
  @@map("supervisor_empresa")
  @@index([empresaId])
  @@index([email])
}

// ---------------------------------------------------------------------
// 4) ESTUDIANTE - Estudiantes que realizan prácticas
// ---------------------------------------------------------------------
model Estudiante {
  id                Int              @id @default(autoincrement())
  usuarioId         Int?             @unique
  usuario           Usuario?         @relation(fields: [usuarioId], references: [id])
  
  rut               String           @unique
  nombre            String
  email             String           @unique
  telefono          String?
  
  // Información académica
  carrera           String
  mencion           String?
  anioIngreso       Int?
  semestreActual    Int?
  promedioGeneral   Float?
  
  // Información personal
  genero            String?
  fechaNacimiento   DateTime?
  direccion         String?
  comuna            String?
  region            String?
  
  // Estado
  activo            Boolean          @default(true)
  fechaRegistro     DateTime         @default(now())
  
  // Relaciones
  practicas         Practica[]
  
  @@map("estudiante")
  @@index([rut])
  @@index([carrera])
  @@index([email])
}

// ---------------------------------------------------------------------
// 5) SOLICITUD DE AUTORIZACION - Documentos formales
//    Solicitudes de autorización enviadas a empresas
// ---------------------------------------------------------------------
model SolicitudAutorizacion {
  id                Int              @id @default(autoincrement())
  codigo            String           @unique  // PHG N°, código único
  
  // Destinatario (Empresa)
  empresaId         Int
  empresa           Empresa          @relation(fields: [empresaId], references: [id])
  nombreDestinatario String
  cargoDestinatario String
  
  // Datos de la carta
  ciudad            String           @default("Arica")
  fechaCarta        DateTime
  asunto            String           @db.Text
  
  // Datos de la práctica solicitada
  tipoPractica      TipoPractica
  carrera           String
  fechaInicio       DateTime
  fechaTermino      DateTime
  
  // Estudiantes (JSON array)
  estudiantesJson   Json             // [{rut, nombre}, ...]
  cantidadEstudiantes Int
  
  // Tutor/Contacto académico
  nombreTutor       String?
  telefonoTutor     String?
  emailTutor        String?
  
  // Estado y seguimiento
  estado            EstadoSolicitud  @default(BORRADOR)
  comentarios       String?          @db.Text
  urlDocumento      String?          // PDF generado
  
  // Metadatos
  creadoPor         String?          // Usuario que creó
  fechaCreacion     DateTime         @default(now())
  fechaActualizacion DateTime        @updatedAt
  fechaEnvio        DateTime?
  fechaRespuesta    DateTime?
  
  @@map("solicitud_autorizacion")
  @@index([codigo])
  @@index([empresaId])
  @@index([estado])
  @@index([fechaCarta])
}

// ---------------------------------------------------------------------
// 6) PRACTICA - Asignación y seguimiento de prácticas
//    Conecta Estudiantes con Empresas y Supervisores
// ---------------------------------------------------------------------
model Practica {
  id                Int              @id @default(autoincrement())
  codigo            String           @unique  // Código único de práctica
  
  // Estudiante
  estudianteId      Int
  estudiante        Estudiante       @relation(fields: [estudianteId], references: [id])
  
  // Empresa
  empresaId         Int
  empresa           Empresa          @relation(fields: [empresaId], references: [id])
  
  // Supervisor asignado
  supervisorId      Int
  supervisor        SupervisorEmpresa @relation(fields: [supervisorId], references: [id])
  
  // Tipo y periodo
  tipo              TipoPractica
  carrera           String
  mencion           String?
  semestre          Int?
  
  // Fechas
  fechaInicio       DateTime
  fechaTermino      DateTime?
  horasTotales      Int?             // Horas totales de práctica
  horasCompletadas  Int?             @default(0)
  
  // Estado
  estado            EstadoPractica   @default(PENDIENTE)
  
  // Área y actividades
  areaAsignada      String?          // Área donde realizará la práctica
  descripcionActividades String?     @db.Text
  
  // Evaluación
  notaFinal         Float?
  comentariosSupervisor String?      @db.Text
  comentariosEstudiante String?      @db.Text
  
  // Documentos
  urlInforme        String?
  urlEvaluacion     String?
  
  // Metadatos
  fechaCreacion     DateTime         @default(now())
  fechaActualizacion DateTime        @updatedAt
  creadoPor         String?
  
  // Relaciones
  actividades       ActividadPractica[]
  asistencias       AsistenciaPractica[]
  
  @@map("practica")
  @@index([estudianteId])
  @@index([empresaId])
  @@index([supervisorId])
  @@index([estado])
  @@index([codigo])
}

// ---------------------------------------------------------------------
// 7) ACTIVIDAD PRACTICA - Actividades y tareas de la práctica
//    Seguimiento detallado de actividades realizadas
// ---------------------------------------------------------------------
model ActividadPractica {
  id                Int              @id @default(autoincrement())
  practicaId        Int
  practica          Practica         @relation(fields: [practicaId], references: [id], onDelete: Cascade)
  
  titulo            String
  descripcion       String?          @db.Text
  fechaRegistro     DateTime         @default(now())
  fechaRealizacion  DateTime?
  horasAsignadas    Int?
  
  // Evidencias
  urlEvidencia      String?
  tipoEvidencia     String?          // foto, documento, video, etc.
  
  // Estado y validación
  completada        Boolean          @default(false)
  validadaSupervisor Boolean         @default(false)
  comentarios       String?          @db.Text
  
  @@map("actividad_practica")
  @@index([practicaId])
}

// ---------------------------------------------------------------------
// 8) ASISTENCIA PRACTICA - Control de asistencia
//    Registro de asistencia del estudiante
// ---------------------------------------------------------------------
model AsistenciaPractica {
  id                Int              @id @default(autoincrement())
  practicaId        Int
  practica          Practica         @relation(fields: [practicaId], references: [id], onDelete: Cascade)
  
  fecha             DateTime
  horaEntrada       DateTime?
  horaSalida        DateTime?
  horasTrabajadas   Float?
  
  presente          Boolean          @default(true)
  justificada       Boolean          @default(false)
  observaciones     String?
  
  @@map("asistencia_practica")
  @@index([practicaId])
  @@index([fecha])
}

// ---------------------------------------------------------------------
// 9) ENCUESTA - Sistema de encuestas y evaluaciones
//    Preguntas genéricas para diferentes tipos de encuestas
// ---------------------------------------------------------------------
model Pregunta {
  id                Int              @id @default(autoincrement())
  descripcion       String           @db.Text
  tipo              String?          // multiple_choice, text, rating, yes_no
  categoria         String?          // satisfaccion, desempeno, instalaciones
  orden             Int?
  activa            Boolean          @default(true)
  
  alternativas      Alternativa[]
  respuestasEstudiante RespuestaEstudiante[]
  respuestasSupervisor RespuestaSupervisor[]
  
  @@map("pregunta")
}

model Alternativa {
  id                Int              @id @default(autoincrement())
  preguntaId        Int
  pregunta          Pregunta         @relation(fields: [preguntaId], references: [id], onDelete: Cascade)
  
  descripcion       String
  puntaje           Int
  orden             Int?
  
  @@map("alternativa")
  @@index([preguntaId])
}

// ---------------------------------------------------------------------
// 10) ENCUESTAS DE EVALUACION
// ---------------------------------------------------------------------
model EncuestaEstudiante {
  id                Int              @id @default(autoincrement())
  practicaId        Int?
  nombreEstudiante  String
  carrera           String
  nombreEmpresa     String
  nombreSupervisor  String?
  fechaEncuesta     DateTime         @default(now())
  
  observaciones     String?          @db.Text
  
  respuestas        RespuestaEstudiante[]
  
  @@map("encuesta_estudiante")
}

model EncuestaSupervisor {
  id                Int              @id @default(autoincrement())
  practicaId        Int?
  nombreSupervisor  String
  nombreEmpresa     String
  nombreEstudiante  String
  carreraEstudiante String
  fechaEncuesta     DateTime         @default(now())
  
  cumplePerfil      Boolean?
  recomendaria      Boolean?
  calificacionGeneral Int?
  sugerencias       String?          @db.Text
  
  respuestas        RespuestaSupervisor[]
  
  @@map("encuesta_supervisor")
}

model RespuestaEstudiante {
  id                Int              @id @default(autoincrement())
  encuestaId        Int
  encuesta          EncuestaEstudiante @relation(fields: [encuestaId], references: [id], onDelete: Cascade)
  preguntaId        Int
  pregunta          Pregunta         @relation(fields: [preguntaId], references: [id])
  
  respuestaTexto    String?          @db.Text
  respuestaNumero   Int?
  alternativaId     Int?
  
  @@map("respuesta_estudiante")
  @@index([encuestaId])
  @@index([preguntaId])
}

model RespuestaSupervisor {
  id                Int              @id @default(autoincrement())
  encuestaId        Int
  encuesta          EncuestaSupervisor @relation(fields: [encuestaId], references: [id], onDelete: Cascade)
  preguntaId        Int
  pregunta          Pregunta         @relation(fields: [preguntaId], references: [id])
  
  respuestaTexto    String?          @db.Text
  respuestaNumero   Int?
  alternativaId     Int?
  
  @@map("respuesta_supervisor")
  @@index([encuestaId])
  @@index([preguntaId])
}
